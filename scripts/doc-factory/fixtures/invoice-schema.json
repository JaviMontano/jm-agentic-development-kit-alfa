{
  "$id": "invoice-v1.0.0",
  "title": "Invoice",
  "type": "object",
  "required": ["folio", "client_name", "items", "date"],
  "properties": {
    "folio": {
      "type": "string",
      "pattern": "^FAC-\\d{4}-\\d{3}$"
    },
    "title": { "type": "string" },
    "client_name": { "type": "string", "minLength": 1 },
    "client_email": { "type": "string" },
    "date": { "type": "string" },
    "currency": { "type": "string", "enum": ["$", "MXN", "USD", "EUR", "COP"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price"],
        "properties": {
          "description": { "type": "string" },
          "quantity": { "type": "number", "minimum": 0.01 },
          "unit_price": { "type": "number", "minimum": 0 }
        }
      }
    },
    "tax_rate": { "type": "number" },
    "notes": { "type": "string" }
  }
}
