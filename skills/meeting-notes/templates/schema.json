{
  "$id": "meeting-notes-v1.0.0",
  "title": "Meeting Notes / Minuta",
  "description": "Schema for structured meeting notes with action items",
  "type": "object",
  "required": ["title", "date", "attendees"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "date": { "type": "string" },
    "time": { "type": "string" },
    "location": { "type": "string" },
    "meeting_type": { "type": "string", "default": "Regular" },
    "facilitator": { "type": "string" },
    "note_taker": { "type": "string" },
    "attendees": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "absent": {
      "type": "array",
      "items": { "type": "string" }
    },
    "agenda": {
      "type": "array",
      "items": { "type": "string" }
    },
    "discussion_points": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "summary": { "type": "string" },
          "decision": { "type": "string" }
        }
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task", "owner"],
        "properties": {
          "task": { "type": "string" },
          "owner": { "type": "string" },
          "deadline": { "type": "string" },
          "priority": { "type": "string", "enum": ["Alta", "Media", "Baja"], "default": "Media" }
        }
      }
    },
    "next_meeting": { "type": "string" },
    "notes": { "type": "string" }
  },
  "outputs": ["md", "html", "docx"],
  "template_version": "1.0.0"
}
