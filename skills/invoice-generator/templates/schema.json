{
  "$id": "invoice-v1.0.0",
  "title": "Invoice / Factura Comercial",
  "description": "Schema for commercial invoices with line items, tax, and totals",
  "type": "object",
  "required": ["folio", "client_name", "items", "date"],
  "properties": {
    "folio": {
      "type": "string",
      "pattern": "^FAC-\\d{4}-\\d{3}$",
      "description": "Auto-generated by folio-generator (FAC-YYYY-NNN)"
    },
    "title": { "type": "string", "default": "Factura" },
    "date": { "type": "string", "description": "Issue date YYYY-MM-DD" },
    "due_date": { "type": "string", "description": "Payment due date" },
    "client_name": { "type": "string", "minLength": 1 },
    "client_email": { "type": "string" },
    "client_address": { "type": "string" },
    "client_rfc": { "type": "string", "description": "Tax ID (RFC in Mexico)" },
    "company_name": { "type": "string", "default": "MetodologIA · JM Labs" },
    "company_address": { "type": "string" },
    "company_rfc": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price"],
        "properties": {
          "description": { "type": "string" },
          "quantity": { "type": "number", "minimum": 0.01 },
          "unit_price": { "type": "number", "minimum": 0 }
        }
      }
    },
    "currency": { "type": "string", "default": "MXN", "enum": ["MXN", "USD", "EUR", "COP"] },
    "tax_rate": { "type": "number", "default": 0.16 },
    "notes": { "type": "string" },
    "payment_method": { "type": "string", "description": "Transferencia, Tarjeta, Efectivo" },
    "bank_account": { "type": "string" }
  },
  "outputs": ["docx", "pdf", "html"],
  "template_version": "1.0.0"
}
