{
  "$id": "acta-formal-v1.0.0",
  "title": "Acta Formal de Reunion",
  "description": "Schema for formal meeting records with attendees, agenda, agreements, and signatures",
  "type": "object",
  "required": ["acta_number", "date", "start_time", "end_time", "attendees", "agenda_items"],
  "properties": {
    "acta_number": {
      "type": "string",
      "pattern": "^MIN-\\d{4}-\\d{3}$",
      "description": "Auto-generated by folio-generator (MIN-YYYY-NNN)"
    },
    "title": { "type": "string", "default": "Acta de Reunion" },
    "date": { "type": "string" },
    "start_time": { "type": "string" },
    "end_time": { "type": "string" },
    "location": { "type": "string" },
    "meeting_type": { "type": "string", "enum": ["Junta de consejo", "Reunion de equipo", "Asamblea", "Comite", "Otro"] },
    "convener_name": { "type": "string" },
    "convener_role": { "type": "string" },
    "attendees": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "attendance": { "type": "string", "enum": ["Presente", "Ausente", "Justificado"], "default": "Presente" }
        }
      }
    },
    "quorum_count": { "type": "integer" },
    "total_invited": { "type": "integer" },
    "quorum_status": { "type": "string", "enum": ["Hay quorum", "No hay quorum"] },
    "agenda_items": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "development_content": { "type": "string", "description": "Desarrollo de la sesion por punto" },
    "agreements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "responsible"],
        "properties": {
          "description": { "type": "string" },
          "responsible": { "type": "string" },
          "deadline": { "type": "string" },
          "status": { "type": "string", "default": "Pendiente" }
        }
      }
    },
    "misc_content": { "type": "string", "description": "Asuntos varios" },
    "next_meeting": { "type": "string" },
    "president_name": { "type": "string" },
    "secretary_name": { "type": "string" }
  },
  "outputs": ["docx", "pdf", "html", "md"],
  "template_version": "1.0.0"
}
